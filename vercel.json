{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html",
      "has": [{ "type": "host", "value": "saeli.org" }]
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html",
      "has": [{ "type": "host", "value": "saeli.org" }]
    },
    {
      "source": "/terms",
      "destination": "/terms.html",
      "has": [{ "type": "host", "value": "saeli.org" }]
    },
    {
      "source": "/privacy-approach",
      "destination": "/privacy-approach.html",
      "has": [{ "type": "host", "value": "saeli.org" }]
    }
  ]
}
