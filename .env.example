# Resend APIキー（/api/contact で使用）
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# 送信元メールアドレス（Resendで検証済みドメインのもの）
RESEND_FROM_EMAIL=noreply@saeli.org

# 問い合わせを受け取るメールアドレス
CONTACT_EMAIL=hello@saeli.org

# SendGrid（/api/revealprop-request で使用、レガシー）
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@saeli.org

NEXT_PUBLIC_GADS_SEND_TO=AW-XXXXXXX/XXXXXXXX

# Supabase（あの子への手紙Web版で使用）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# あの子カフェジェネレーター（/letters-admin/generator）
# city-api経由でGemini呼ぶのでGEMINI_API_KEYは不要
LETTERS_ADMIN_PASSWORD=your_admin_password
